---
import '../styles/custom.css';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const documentationUrl = `${baseUrl}/walkthrough-repro/`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="ALVIE: active learning for Sancus security analysis." />
    <title>ALVIE</title>
  </head>
  <body>
    <main class="alvie-home">
      <h1>ALVIE</h1>
      <nav aria-label="ALVIE links">
        <a href="https://github.com/unive-alvie/alvie">repo</a>
        <a href="https://arxiv.org/abs/2404.09518">paper</a>
        <a href={documentationUrl}>documentation</a>
      </nav>
    </main>
  </body>
</html>
